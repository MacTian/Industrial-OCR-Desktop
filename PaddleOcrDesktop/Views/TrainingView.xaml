<!-- Views/TrainingView.xaml -->
<UserControl x:Class="PaddleOcrDesktop.Views.TrainingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="200"/>
        </Grid.RowDefinitions>

        <!-- 工具栏 -->
        <ToolBarTray Grid.Row="0">
            <ToolBar>
                <Button Content="🚀 一键配置" Command="{Binding AutoConfigureCommand}" Margin="4"
                        ToolTip="自动配置训练环境（克隆仓库、安装依赖、下载模型）"/>
                <Separator/>
                <Button Content="▶️ 开始训练" Command="{Binding StartTrainingCommand}" Margin="4"/>
                <Button Content="⏹️ 停止训练" Command="{Binding StopTrainingCommand}" Margin="4"/>
                <Separator/>
                <Button Content="🔍 环境检查" Command="{Binding CheckEnvironmentCommand}" Margin="4"/>
                <Button Content="📋 生成配置" Command="{Binding GenerateConfigCommand}" Margin="4"/>
            </ToolBar>
        </ToolBarTray>

        <!-- 配置区 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16">
                <GroupBox Header="基本设置" Margin="0,0,0,12">
                    <Grid Margin="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="训练类型:" VerticalAlignment="Center" Margin="4"/>
                        <ComboBox Grid.Row="0" Grid.Column="1" Margin="4"
                                  SelectedItem="{Binding Config.Mode}">
                            <ComboBoxItem Content="检测 (Detection)" Tag="{x:Static models:TrainingMode.Detection}" xmlns:models="clr-namespace:PaddleOcrDesktop.Models"/>
                            <ComboBoxItem Content="识别 (Recognition)" Tag="{x:Static models:TrainingMode.Recognition}" xmlns:models="clr-namespace:PaddleOcrDesktop.Models"/>
                        </ComboBox>

                        <TextBlock Grid.Row="0" Grid.Column="2" Text="训练设备:" VerticalAlignment="Center" Margin="4"/>
                        <ComboBox Grid.Row="0" Grid.Column="3" Margin="4"
                                  SelectedItem="{Binding Config.Device}">
                            <ComboBoxItem Content="CPU" Tag="{x:Static models:TrainingDevice.CPU}" xmlns:models="clr-namespace:PaddleOcrDesktop.Models"/>
                            <ComboBoxItem Content="GPU" Tag="{x:Static models:TrainingDevice.GPU}" xmlns:models="clr-namespace:PaddleOcrDesktop.Models"/>
                        </ComboBox>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="数据目录:" VerticalAlignment="Center" Margin="4"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="4"
                                 Text="{Binding Config.DataDir}"/>
                        <Button Grid.Row="1" Grid.Column="3" Content="浏览..." Margin="4"
                                Command="{Binding BrowseDataDirCommand}"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="标签文件:" VerticalAlignment="Center" Margin="4"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Margin="4"
                                 Text="{Binding Config.LabelFilePath}"/>
                        <Button Grid.Row="2" Grid.Column="3" Content="浏览..." Margin="4"
                                Command="{Binding BrowseLabelFileCommand}"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="输出目录:" VerticalAlignment="Center" Margin="4"/>
                        <TextBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Margin="4"
                                 Text="{Binding Config.OutputDir}"/>
                        <Button Grid.Row="3" Grid.Column="3" Content="浏览..." Margin="4"
                                Command="{Binding BrowseOutputDirCommand}"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="PaddleOCR目录:" VerticalAlignment="Center" Margin="4"/>
                        <TextBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" Margin="4"
                                 Text="{Binding PaddleocrDir}"/>
                        <Button Grid.Row="4" Grid.Column="3" Content="浏览..." Margin="4"
                                Command="{Binding BrowsePaddleocrDirCommand}"/>
                    </Grid>
                </GroupBox>

                <GroupBox Header="训练参数" Margin="0,0,0,12">
                    <Grid Margin="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="学习率:" VerticalAlignment="Center" Margin="4"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Margin="4" Text="{Binding Config.LearningRate}"/>

                        <TextBlock Grid.Row="0" Grid.Column="2" Text="训练轮数:" VerticalAlignment="Center" Margin="4"/>
                        <TextBox Grid.Row="0" Grid.Column="3" Margin="4" Text="{Binding Config.Epochs}"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="批大小:" VerticalAlignment="Center" Margin="4"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Margin="4" Text="{Binding Config.BatchSize}"/>

                        <TextBlock Grid.Row="1" Grid.Column="2" Text="工作进程:" VerticalAlignment="Center" Margin="4"/>
                        <TextBox Grid.Row="1" Grid.Column="3" Margin="4" Text="{Binding Config.NumWorkers}"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="GPU ID:" VerticalAlignment="Center" Margin="4"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Margin="4" Text="{Binding Config.GpuDeviceId}"/>

                        <TextBlock Grid.Row="2" Grid.Column="2" Text="预训练模型:" VerticalAlignment="Center" Margin="4"
                                   ToolTip="包含 .pdmodel 和 .pdparams 文件的目录，留空则从头训练"/>
                        <Grid Grid.Row="2" Grid.Column="3" Margin="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding Config.PretrainedModelDir}"
                                     ToolTip="包含 .pdmodel 和 .pdparams 文件的目录，留空则从头训练"/>
                            <Button Grid.Column="1" Content="🔍" Margin="2,0,0,0" Padding="4,0"
                                    ToolTip="自动检测预训练模型"
                                    Command="{Binding AutoDetectPretrainedModelCommand}"/>
                            <Button Grid.Column="2" Content="浏览..." Margin="2,0,0,0"
                                    Command="{Binding BrowsePretrainedModelCommand}"/>
                        </Grid>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="字典文件:" VerticalAlignment="Center" Margin="4"
                                   ToolTip="识别模式必须，每行一个字符的文本文件"/>
                        <Grid Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Margin="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding Config.DictFilePath}"
                                     ToolTip="识别模式必须，每行一个字符的文本文件"/>
                            <Button Grid.Column="1" Content="🔍" Margin="2,0,0,0" Padding="4,0"
                                    ToolTip="自动检测字典文件"
                                    Command="{Binding AutoDetectDictFileCommand}"/>
                            <Button Grid.Column="2" Content="浏览..." Margin="2,0,0,0"
                                    Command="{Binding BrowseDictFileCommand}"/>
                        </Grid>
                        <TextBlock Grid.Row="3" Grid.Column="3" Text="rec必填" VerticalAlignment="Center"
                                   Foreground="Gray" FontSize="10"/>
                    </Grid>
                </GroupBox>

                <GroupBox Header="🚀 一键自动配置" Margin="0,0,0,8">
                    <StackPanel Margin="8">
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,8" Foreground="Gray">
                            一键完成：克隆 PaddleOCR 仓库 / 安装 PaddlePaddle / 安装依赖 / 下载预训练模型。
                            配置完成后自动填入训练参数。
                        </TextBlock>
                        <WrapPanel Margin="0,0,0,8">
                            <CheckBox Content="下载预训练模型" IsChecked="{Binding ConfigureDownloadPretrained}"
                                      Margin="0,0,16,4" VerticalAlignment="Center"/>
                            <CheckBox Content="安装 PaddlePaddle" IsChecked="{Binding ConfigureInstallPaddle}"
                                      Margin="0,0,16,4" VerticalAlignment="Center"/>
                            <CheckBox Content="安装依赖 (requirements.txt)" IsChecked="{Binding ConfigureInstallDeps}"
                                      Margin="0,0,16,4" VerticalAlignment="Center"/>
                        </WrapPanel>
                        <Button Content="🚀 开始自动配置" Command="{Binding AutoConfigureCommand}"
                                HorizontalAlignment="Left" Padding="16,4" Margin="0,0,0,8"
                                IsEnabled="{Binding IsConfiguring, Converter={StaticResource BoolInvert}}"/>
                        <ProgressBar IsIndeterminate="{Binding IsConfiguring}" Height="4" Margin="0,0,0,4"
                                     Visibility="{Binding IsConfiguring, Converter={StaticResource BoolToVis}}"/>
                        <TextBlock Text="{Binding CurrentConfigureStep}" FontWeight="Bold" Margin="0,0,0,4"
                                   Visibility="{Binding IsConfiguring, Converter={StaticResource BoolToVis}}"/>
                        <Expander Header="配置日志" IsExpanded="False"
                                  Visibility="{Binding ConfigureLog, Converter={StaticResource EmptyToVis}}">
                            <TextBox Text="{Binding ConfigureLog, Mode=OneWay}"
                                     IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                                     MaxHeight="120" FontFamily="Consolas" FontSize="10"
                                     TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </Expander>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="状态" Margin="0,0,0,8">
                    <StackPanel Margin="8">
                        <TextBlock Text="{Binding StatusMessage}" FontWeight="Bold" Margin="4"
                                   TextWrapping="Wrap"/>
                        <ProgressBar Value="{Binding TrainingProgress}" Height="20" Margin="4"
                                     IsIndeterminate="{Binding IsTrainingRunning}"/>
                    </StackPanel>
                </GroupBox>

                <Expander Header="📖 环境依赖指南" Margin="0,0,0,8" IsExpanded="False">
                    <StackPanel Margin="12,8">
                        <TextBlock FontWeight="Bold" Margin="0,0,0,4">训练需要以下依赖：</TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="4,2">
                            1. Python 3.8+ — https://www.python.org/downloads/
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="4,2">
                            2. PaddlePaddle — CPU: pip install paddlepaddle / GPU: pip install paddlepaddle-gpu
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="4,2">
                            3. PaddleOCR 源码 — git clone https://github.com/PaddlePaddle/PaddleOCR.git
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="4,2">
                            4. PaddleOCR 依赖 — cd PaddleOCR &amp;&amp; pip install -r requirements.txt
                        </TextBlock>
                        <Separator Margin="0,8"/>
                        <TextBlock FontWeight="Bold" Margin="0,0,0,4">预训练模型（微调时必需）：</TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="4,2">
                            检测模型：https://paddleocr.bj.bcebos.com/PP-OCRv5/chinese/ch_PP-OCRv5_det_infer.tar
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="4,2">
                            识别模型：https://paddleocr.bj.bcebos.com/PP-OCRv5/chinese/ch_PP-OCRv5_rec_infer.tar
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="4,2">
                            解压后将 .pdmodel 和 .pdparams 放入 inference/ 目录，点击 🔍 自动检测
                        </TextBlock>
                        <Separator Margin="0,8"/>
                        <TextBlock FontWeight="Bold" Margin="0,0,0,4">字典文件（识别模式必需）：</TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="4,2">
                            字典文件通常位于 PaddleOCR/ppocr/utils/ 目录下。
                            本应用自带 ppocrv5_dict.txt，点击 🔍 自动检测。
                        </TextBlock>
                        <Separator Margin="0,8"/>
                        <TextBlock FontWeight="Bold" Margin="0,0,0,4">目录结构示例：</TextBlock>
                        <TextBlock FontFamily="Consolas" FontSize="11" TextWrapping="Wrap" Margin="4,2"
                                   xml:space="preserve">
PaddleOCR/
├── tools/train.py          ← 训练脚本
├── ppocr/                  ← 模型定义
├── configs/                ← 配置模板
└── requirements.txt        ← Python 依赖</TextBlock>
                        <Separator Margin="0,8"/>
                        <TextBlock FontWeight="Bold" Margin="0,0,0,4">操作步骤：</TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="4,2" LineHeight="20">
                            ① 在「标注模式」中导出训练数据<LineBreak/>
                            ② 设置 PaddleOCR 目录（克隆的仓库路径）<LineBreak/>
                            ③ 点击「环境检查」确认依赖就绪<LineBreak/>
                            ④ 点击「生成配置」创建 YAML 配置文件<LineBreak/>
                            ⑤ 点击「开始训练」启动训练
                        </TextBlock>
                    </StackPanel>
                </Expander>
            </StackPanel>
        </ScrollViewer>

        <!-- 日志区 -->
        <GroupBox Grid.Row="2" Header="训练日志" Margin="4">
            <TextBox Text="{Binding TrainingLog, Mode=OneWay}"
                     IsReadOnly="True"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     TextWrapping="Wrap"
                     FontFamily="Consolas"
                     FontSize="11"/>
        </GroupBox>
    </Grid>
</UserControl>
