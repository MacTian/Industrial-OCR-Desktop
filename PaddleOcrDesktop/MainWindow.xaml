<!-- MainWindow.xaml -->
<Window x:Class="PaddleOcrDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:PaddleOcrDesktop.Views"
        Title="工业文字识别系统" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 工具栏 -->
        <ToolBarTray Grid.Row="0">
            <ToolBar>
                <Button Content="📂 打开图片" Command="{Binding OpenImageCommand}" Margin="4"/>
                <Button Content="📁 打开文件夹" Command="{Binding OpenFolderCommand}" Margin="4"/>
                <Separator/>
                <Button Content="🔍 开始识别" Command="{Binding RecognizeCommand}" Margin="4"/>
                <Button Content="🔄 批量识别" Command="{Binding RecognizeBatchCommand}" Margin="4"/>
                <Button Content="❌ 清除ROI" Command="{Binding ClearRoiCommand}" Margin="4"/>
                <Separator/>
                <Button Content="💾 导出结果" Command="{Binding ExportResultsCommand}" Margin="4"/>
            </ToolBar>
        </ToolBarTray>

        <!-- 主内容区：TabControl -->
        <TabControl Grid.Row="1" x:Name="MainTabControl">
            <!-- Tab 1: 识别模式 -->
            <TabItem Header="🔍 识别模式">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" MinWidth="150"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="300" MinWidth="200"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左侧：文件列表 -->
                    <GroupBox Grid.Column="0" Header="文件列表">
                        <ListBox ItemsSource="{Binding ImageFiles}"
                                 SelectedItem="{Binding SelectedImageFile}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource FileNameConv}}"
                                               TextTrimming="CharacterEllipsis" ToolTip="{Binding}"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </GroupBox>

                    <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"/>

                    <!-- 中间：图片预览 -->
                    <GroupBox Grid.Column="2" Header="图片预览">
                        <views:ImageView x:Name="ImageViewControl"/>
                    </GroupBox>

                    <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch"/>

                    <!-- 右侧：识别结果 -->
                    <GroupBox Grid.Column="4" Header="识别结果">
                        <views:ResultPanel x:Name="ResultPanelControl"/>
                    </GroupBox>
                </Grid>
            </TabItem>

            <!-- Tab 2: 标注模式 -->
            <TabItem Header="✏️ 标注模式">
                <views:AnnotationView x:Name="AnnotationViewControl"/>
            </TabItem>

            <!-- Tab 3: 训练模式 -->
            <TabItem Header="🏋️ 训练">
                <views:TrainingView x:Name="TrainingViewControl"/>
            </TabItem>
        </TabControl>

        <!-- 状态栏 -->
        <StatusBar Grid.Row="2">
            <StatusBarItem>
                <TextBlock Text="{Binding ModelStatus}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding ResultViewModel.StatusMessage}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <ProgressBar Value="{Binding BatchProgress}" Width="150" Height="16"
                             Visibility="{Binding ResultViewModel.IsRecognizing, Converter={StaticResource BoolToVis}}"/>
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock Text="{Binding BatchStatus}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
